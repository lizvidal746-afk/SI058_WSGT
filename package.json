{
  "name": "si058-k6-stress",
  "version": "1.0.0",
  "description": "Pruebas de rendimiento y estres para SUNEDU SI058 con k6 + Grafana Cloud. Alineado a ISTQB Performance Testing e ISO/IEC 25010/25023.",
  "private": true,
  "scripts": {
    "smoke": "npm run perf:smoke",
    "smoke:carnet": "npm run perf:carnet:smoke",
    "smoke:grados": "npm run perf:grados:smoke",
    "smoke:all": "npm run perf:carnet:smoke && npm run perf:grados:smoke",

    "perf:smoke":  "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='smoke'; $env:TEST_CASE_ID='CP-MIX-00'; powershell -File tools/run-k6.ps1 scripts/performance.js\"",
    "perf:carnet:smoke": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='smoke'; $env:TEST_CASE_ID='CP-CAR-00'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:grados:smoke": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='smoke'; $env:TEST_CASE_ID='CP-GRA-00'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "load": "npm run perf:load",
    "stress": "npm run perf:stress",
    "breakpoint": "npm run perf:cp03",
    "spike": "npm run perf:spike",
    "perf:load":   "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='load'; $env:TEST_CASE_ID='CP-CAR-02'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:stress": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='stress'; $env:TEST_CASE_ID='CP-CAR-03'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:spike":  "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='spike'; $env:TEST_CASE_ID='CP-CAR-07'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:soak":   "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='soak'; $env:TEST_CASE_ID='CP-CAR-08'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:collapse": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='collapse'; $env:TEST_CASE_ID='CP-CAR-06'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:all:load": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='load'; powershell -File tools/run-k6.ps1 scripts/performance.js\"",
    "perf:all:stress": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='stress'; powershell -File tools/run-k6.ps1 scripts/performance.js\"",
    "perf:all:spike": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='spike'; powershell -File tools/run-k6.ps1 scripts/performance.js\"",
    "perf:all:soak": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='soak'; powershell -File tools/run-k6.ps1 scripts/performance.js\"",
    "perf:all:cp03": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='cp03'; powershell -File tools/run-k6.ps1 scripts/performance.js\"",
    "perf:all:collapse": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='collapse'; powershell -File tools/run-k6.ps1 scripts/performance.js\"",
    "perf:cp01":   "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='cp01'; $env:TEST_CASE_ID='CP-CAR-04'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:cp02":   "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='cp02'; $env:TEST_CASE_ID='CP-CAR-02'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:cp03":   "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='cp03'; $env:TEST_CASE_ID='CP-CAR-05'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:grados:load": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='load'; $env:TEST_CASE_ID='CP-GRA-02'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:grados:cp02": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='cp02'; $env:TEST_CASE_ID='CP-GRA-02'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:grados:collapse": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='collapse'; $env:TEST_CASE_ID='CP-GRA-06'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:grados:stress": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='stress'; $env:TEST_CASE_ID='CP-GRA-03'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:grados:spike": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='spike'; $env:TEST_CASE_ID='CP-GRA-07'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:grados:soak": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='soak'; $env:TEST_CASE_ID='CP-GRA-08'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:grados:cp01": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='cp01'; $env:TEST_CASE_ID='CP-GRA-04'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:grados:cp03": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='cp03'; $env:TEST_CASE_ID='CP-GRA-05'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "perf:audit":  "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='multi_ip_audit'; $env:TEST_CASE_ID='CP-CAR-01'; powershell -File tools/run-k6.ps1 scripts/carnet.js\"",
    "perf:grados:audit": "powershell -ExecutionPolicy Bypass -Command \"$env:SCENARIO='multi_ip_audit'; $env:TEST_CASE_ID='CP-GRA-01'; powershell -File tools/run-k6.ps1 scripts/grados.js\"",
    "cloud:smoke": "node tools/pending.js cloud",
    "cloud:load": "node tools/pending.js cloud",
    "cloud:stress": "node tools/pending.js cloud",
    "cloud:breakpoint": "node tools/pending.js cloud",
    "cloud:spike": "node tools/pending.js cloud",
    "smoke:prometheus": "node tools/pending.js prometheus",
    "load:prometheus": "node tools/pending.js prometheus",
    "stress:prometheus": "node tools/pending.js prometheus",
    "breakpoint:prometheus": "node tools/pending.js prometheus",
    "spike:prometheus": "node tools/pending.js prometheus",
    "prometheus:breakpoint": "node tools/pending.js prometheus",

    "ips:setup": "powershell -ExecutionPolicy Bypass -File tools/setup-ips.ps1",
    "ips:remove": "powershell -ExecutionPolicy Bypass -File tools/remove-ips.ps1",
    "ips:verify": "powershell -ExecutionPolicy Bypass -File tools/verify-ips.ps1",
    "report:excel": "node tools/generar-excel.js",
    "report:word": "node tools/generar-word.js",
    "report:plan": "node tools/generar-plan-excel.js",
    "report:template": "node tools/generar-plantilla-evidencia.js",
    "report:all": "npm run report:excel && npm run report:word && npm run report:template && npm run report:plan"
