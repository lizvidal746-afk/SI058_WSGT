# ============================================================
# SI058_K6_STRESS - Plantilla de variables de entorno
# Copiar a .env y completar valores reales. NUNCA versionar .env
# ============================================================

# --- Endpoints ---
BASE_URL=https://serviciosgytapiqa.sunedu.gob.pe

# --- IPs de origen para k6 (K6_LOCAL_IPS) ---
# WiFi / una sola maquina: deja esta linea COMENTADA o pon solo tu IP DHCP real, p. ej.:
#   K6_LOCAL_IPS=192.168.28.8
# Asi k6 no intenta salir por alias que en WiFi pueden dar problemas de ruta o ARP.
# Varias IPs (round-robin): tras ejecutar tools/setup-ips.ps1 como admin, descomenta p. ej.:
#   K6_LOCAL_IPS=192.168.28.48-192.168.28.57
#K6_LOCAL_IPS=192.168.28.8

# --- Credenciales de prueba (entorno QA, datos sinteticos) ---
SUNEDU_USUARIO_1=USUARIO_QA_1
SUNEDU_CLAVE_1=CLAVE_QA_1
SUNEDU_DOC_1=00000000
SUNEDU_ENTIDAD_1=5

SUNEDU_USUARIO_2=USUARIO_QA_2
SUNEDU_CLAVE_2=CLAVE_QA_2
SUNEDU_DOC_2=00000000
SUNEDU_ENTIDAD_2=11

# --- Grafana Cloud k6 (free tier) ---
# Obtener desde: https://app.k6.io/account/api-token
K6_CLOUD_TOKEN=

# --- Prometheus Remote Write (Grafana Cloud free) ---
# Obtener desde Grafana Cloud -> Connections -> Prometheus -> Send Metrics
K6_PROMETHEUS_RW_USERNAME=
K6_PROMETHEUS_RW_PASSWORD=
K6_PROMETHEUS_RW_SERVER_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
K6_PROMETHEUS_RW_TREND_STATS=p(50),p(90),p(95),p(99),min,max,avg

# --- Tags para clasificar runs en Grafana ---
TEST_ID=local-dev
ENVIRONMENT=qa
TESTER=ingenieria-qa
